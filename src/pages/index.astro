---
import Layout from '../layouts/Layout.astro';
import ChatDemo from '../components/ChatDemo';
import ContactForm from '../components/ContactForm';
---

<Layout>
  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/logo_sin_fondo.png" alt="Dalsat logo" class="h-11 w-auto" />
        <span class="font-bold text-gray-900 text-lg">Dalsat</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
        <a href="#como-funciona" class="hover:text-[#128C7E] transition-colors">Cómo funciona</a>
        <a href="#funcionalidades" class="hover:text-[#128C7E] transition-colors">Funcionalidades</a>
        <a href="#prueba-social" class="hover:text-[#128C7E] transition-colors">Casos reales</a>
        <a href="#quienes-somos" class="hover:text-[#128C7E] transition-colors">Quiénes somos</a>
      </nav>
      <a
        href="#contacto"
        class="bg-[#25D366] hover:bg-[#128C7E] text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors shadow-sm"
      >
        Empezar →
      </a>
    </div>
  </header>

  <main class="pt-16">
    <!-- ===================== HERO ===================== -->
    <section class="relative overflow-hidden bg-gradient-to-br from-white via-green-50/30 to-white pt-20 pb-24 sm:pt-28 sm:pb-32">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full bg-[#25D366]/5 translate-x-1/3 -translate-y-1/3" />
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-[#25D366]/5 -translate-x-1/3 translate-y-1/3" />
      </div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-green-50 border border-green-100 text-[#128C7E] text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-[#25D366] animate-pulse" />
            Responde en segundos, 24/7
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight mb-6">
            Tu negocio responde en&nbsp;
            <span class="text-[#128C7E]">WhatsApp</span> aunque duermas
          </h1>
          <p class="text-lg sm:text-xl text-gray-500 mb-10 leading-relaxed max-w-lg">
            Dalsat despliega un agente de IA en tu WhatsApp en minutos. Solo cuéntale cómo es tu negocio — él responde, nunca se cansa y escala a un humano cuando lo necesita.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contacto"
              class="inline-flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#128C7E] text-white font-semibold px-8 py-4 rounded-xl transition-colors shadow-lg shadow-green-200 text-base"
            >
              Pruébalo para tu negocio
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex items-center justify-center gap-2 text-gray-600 hover:text-[#128C7E] font-medium px-8 py-4 rounded-xl border border-gray-200 hover:border-[#25D366] transition-colors text-base"
            >
              Ver cómo funciona
            </a>
          </div>
          <div class="mt-10 flex items-center gap-6 text-sm text-gray-400">
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Sin código
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Listo en minutos
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              24/7 activo
            </div>
          </div>
        </div>

        <!-- Chat preview hero -->
        <div class="lg:flex justify-center hidden">
          <ChatDemo client:visible />
        </div>
      </div>
    </section>

    <!-- ===================== PROBLEMA / SOLUCIÓN ===================== -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <!-- Problema -->
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-red-500 mb-4 block">El problema</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
              Las preguntas repetitivas te roban horas cada día
            </h2>
            <ul class="space-y-4">
              {[
                '¿A qué hora abrís?',
                '¿Cuánto cuesta?',
                '¿Tenéis hueco el viernes?',
                '¿Qué documentos necesito?',
              ].map((q) => (
                <li class="flex items-start gap-3 p-4 bg-white rounded-xl border border-gray-100 shadow-sm">
                  <span class="text-red-400 mt-0.5">✕</span>
                  <div>
                    <p class="font-medium text-gray-800">"{q}"</p>
                    <p class="text-sm text-gray-400 mt-0.5">Respondida manualmente, decenas de veces al día.</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <!-- Solución -->
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-[#25D366] mb-4 block">La solución</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
              Dalsat responde por ti, al instante
            </h2>
            <div class="space-y-4">
              {[
                {
                  icon: '⚡',
                  title: 'Respuesta en segundos',
                  desc: 'Tu agente contesta en tiempo real, a cualquier hora, sin que tú hagas nada.',
                },
                {
                  icon: '🎯',
                  title: 'Respuestas precisas',
                  desc: 'Conoce tu negocio a fondo: precios, horarios, FAQs, documentos.',
                },
                {
                  icon: '🤝',
                  title: 'Escala cuando toca',
                  desc: 'Si el cliente necesita un humano, te avisa con un resumen completo.',
                },
              ].map((item) => (
                <div class="flex items-start gap-4 p-4 bg-white rounded-xl border border-gray-100 shadow-sm">
                  <span class="text-2xl">{item.icon}</span>
                  <div>
                    <p class="font-semibold text-gray-900">{item.title}</p>
                    <p class="text-sm text-gray-500 mt-0.5">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CÓMO FUNCIONA ===================== -->
    <section id="como-funciona" class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
        <span class="text-xs font-bold uppercase tracking-widest text-[#128C7E] mb-4 block">Proceso</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Listo en 3 pasos</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto mb-16">
          Sin técnicos, sin semanas de configuración. Tu agente activo hoy mismo.
        </p>

        <div class="grid md:grid-cols-3 gap-8 relative">
          <!-- línea conectora -->
          <div class="hidden md:block absolute top-12 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-[#25D366] to-[#128C7E] opacity-30" />

          {[
            {
              step: '01',
              icon: '📋',
              title: 'Configuras tu negocio',
              desc: 'Nos cuentas quién eres: horarios, precios, FAQs, tono de voz. Puedes subir PDFs, Word o Excel.',
            },
            {
              step: '02',
              icon: '🤖',
              title: 'Dalsat aprende solo',
              desc: 'Nuestro sistema procesa tu información y crea la base de conocimiento de tu agente. Sin ingeniería de prompts.',
            },
            {
              step: '03',
              icon: '💬',
              title: 'Tu WhatsApp responde',
              desc: 'Tus clientes escriben y reciben respuestas precisas al instante. Tú solo ves las conversaciones que necesitan tu atención.',
            },
          ].map((item) => (
            <div class="relative bg-gray-50 rounded-2xl p-8 text-left border border-gray-100 hover:border-[#25D366]/30 hover:shadow-lg transition-all">
              <div class="text-4xl mb-4">{item.icon}</div>
              <div class="text-xs font-bold text-[#25D366] mb-2">PASO {item.step}</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== FUNCIONALIDADES ===================== -->
    <section id="funcionalidades" class="py-24 bg-gradient-to-br from-[#0B5E55] to-[#128C7E]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16">
          <span class="text-xs font-bold uppercase tracking-widest text-[#25D366] mb-4 block">Capacidades</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Todo lo que necesitas. Integrado.</h2>
          <p class="text-white/60 text-lg max-w-xl mx-auto">
            Dalsat no es un chatbot genérico. Es un agente que conoce tu negocio.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            {
              icon: '🏢',
              title: 'Multi-negocio',
              desc: 'Una plataforma gestiona múltiples negocios. Cada uno con su base de conocimiento y historial aislados.',
            },
            {
              icon: '🔍',
              title: 'Búsqueda semántica',
              desc: 'Encuentra la información correcta ante cada pregunta, aunque el cliente no use las palabras exactas.',
            },
            {
              icon: '🧠',
              title: 'Memoria de conversación',
              desc: 'Recuerda los últimos 20 mensajes. Los clientes no tienen que repetirse.',
            },
            {
              icon: '📤',
              title: 'Escalado inteligente',
              desc: 'Detecta cuándo escalar a humano. Notifica con resumen completo de la conversación.',
            },
            {
              icon: '📁',
              title: 'Ingestión de documentos',
              desc: 'Sube PDFs, Word y Excel. Dalsat los convierte y los añade a su base de conocimiento.',
            },
            {
              icon: '🛡️',
              title: 'Protección anti-flood',
              desc: 'Control integrado contra mensajes en ráfaga. Costes de API bajo control.',
            },
          ].map((f) => (
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:bg-white/15 transition-colors">
              <div class="text-3xl mb-4">{f.icon}</div>
              <h3 class="text-white font-semibold text-base mb-2">{f.title}</h3>
              <p class="text-white/60 text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== DIFERENCIADORES ===================== -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Dalsat vs. las alternativas</h2>
          <p class="text-gray-500">Por qué no lo hacen igual que nosotros.</p>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100">
                <th class="text-left py-4 pr-4 text-gray-400 font-medium w-1/3"></th>
                <th class="text-center py-4 px-3 text-gray-400 font-medium">Chatbots genéricos</th>
                <th class="text-center py-4 px-3 text-gray-400 font-medium">IA a medida</th>
                <th class="text-center py-4 px-3 bg-green-50 rounded-t-xl font-bold text-[#128C7E]">Dalsat</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['Tiempo de configuración', 'Días–semanas', 'Semanas–meses', 'Minutos'],
                ['Conoce tu negocio', 'Entrenamiento manual', 'Desarrollo a medida', 'Auto desde config'],
                ['WhatsApp nativo', 'Raramente', 'A veces', 'Siempre'],
                ['Escalado a humano', 'Limitado', 'A medida', 'Integrado'],
                ['Multi-tenant', '✕', '✕', '✓'],
                ['Precio', 'Medio', 'Alto', 'Asequible'],
              ].map(([label, chatbot, custom, dalsat]) => (
                <tr class="border-b border-gray-50">
                  <td class="py-4 pr-4 text-gray-700 font-medium">{label}</td>
                  <td class="py-4 px-3 text-center text-gray-400">{chatbot}</td>
                  <td class="py-4 px-3 text-center text-gray-400">{custom}</td>
                  <td class="py-4 px-3 text-center bg-green-50 text-[#128C7E] font-semibold">{dalsat}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ===================== PRUEBA SOCIAL ===================== -->
    <section id="prueba-social" class="py-24 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16">
          <span class="text-xs font-bold uppercase tracking-widest text-[#128C7E] mb-4 block">Caso real</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
            Autoescuela Reyes — Valencia
          </h2>
          <p class="text-gray-500 text-lg max-w-xl mx-auto">
            Responde sobre carnets, precios, documentación y proceso de examen. Disponible 24/7. Escala a humano para consultas personalizadas.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            {[
              {
                icon: '🚗',
                label: 'Carnets gestionados',
                value: 'B, A2, AM',
                desc: 'Responde con detalle sobre cada tipo de carnet',
              },
              {
                icon: '⏰',
                label: 'Disponibilidad',
                value: '24 / 7',
                desc: 'Consultas fuera de horario resueltas sin personal',
              },
              {
                icon: '📞',
                label: 'Escalado automático',
                value: 'Activo',
                desc: 'Expedientes concretos y fechas de examen → humano',
              },
              {
                icon: '🗣️',
                label: 'Tono de voz',
                value: 'Cercano',
                desc: 'Español informal, adaptado a la marca de la autoescuela',
              },
            ].map((stat) => (
              <div class="flex items-start gap-4 p-5 bg-white rounded-2xl border border-gray-100 shadow-sm">
                <span class="text-2xl">{stat.icon}</span>
                <div class="flex-1">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-500">{stat.label}</span>
                    <span class="font-bold text-[#128C7E] text-sm">{stat.value}</span>
                  </div>
                  <p class="text-xs text-gray-400 mt-0.5">{stat.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <ChatDemo client:visible />
        </div>
      </div>
    </section>

    <!-- ===================== STACK TÉCNICO ===================== -->
    <section class="py-16 bg-white border-t border-gray-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-8">Stack tecnológico</p>
        <div class="flex flex-wrap justify-center gap-4">
          {[
            { name: 'Google Gemini', color: 'bg-blue-50 text-blue-700 border-blue-100' },
            { name: 'WhatsApp (Evolution API)', color: 'bg-green-50 text-green-700 border-green-100' },
            { name: 'LlamaIndex', color: 'bg-purple-50 text-purple-700 border-purple-100' },
            { name: 'ChromaDB', color: 'bg-orange-50 text-orange-700 border-orange-100' },
            { name: 'Redis', color: 'bg-red-50 text-red-700 border-red-100' },
            { name: 'FastAPI', color: 'bg-teal-50 text-teal-700 border-teal-100' },
            { name: 'Docker', color: 'bg-sky-50 text-sky-700 border-sky-100' },
          ].map((tech) => (
            <span class={`px-4 py-2 rounded-full text-xs font-semibold border ${tech.color}`}>
              {tech.name}
            </span>
          ))}
        </div>
        <p class="text-xs text-gray-400 mt-6">Desplegable en cualquier VPS. Infraestructura propia, datos en tu servidor.</p>
      </div>
    </section>

    <!-- ===================== QUIÉNES SOMOS ===================== -->
    <section id="quienes-somos" class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <!-- Logo mark centrado -->
        <div class="flex justify-center mb-14">
          <img
            src="/logo_sin_fondo.png"
            alt="Dalsat"
            class="h-36 w-auto drop-shadow-md"
          />
        </div>
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Texto -->
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-[#128C7E] mb-4 block">Quiénes somos</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
              Construido por gente que entiende tu negocio
            </h2>
            <p class="text-gray-500 text-lg leading-relaxed mb-6">
              Dalsat nació de una frustración real: ver cómo negocios brillantes perdían clientes por no poder responder a tiempo en WhatsApp.
            </p>
            <p class="text-gray-500 leading-relaxed mb-6">
              Somos un equipo técnico con experiencia en inteligencia artificial y automatización. No vendemos humo — desplegamos agentes reales, en producción, para negocios reales. Cada integración la supervisamos de principio a fin.
            </p>
            <p class="text-gray-500 leading-relaxed">
              Nuestra obsesión es que el agente hable exactamente como tú lo harías. Que tus clientes nunca noten la diferencia — excepto que ahora siempre tienen respuesta, incluso a las 2 de la madrugada.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              {[
                { label: 'Agentes desplegados', value: '10+' },
                { label: 'Mensajes gestionados', value: '50.000+' },
                { label: 'Disponibilidad', value: '99,9 %' },
              ].map((stat) => (
                <div class="bg-gray-50 rounded-2xl px-6 py-4 border border-gray-100 text-center">
                  <div class="text-2xl font-extrabold text-[#128C7E]">{stat.value}</div>
                  <div class="text-xs text-gray-500 mt-0.5">{stat.label}</div>
                </div>
              ))}
            </div>
          </div>

          <!-- Tarjetas equipo / valores -->
          <div class="space-y-5">
            {[
              {
                icon: '🔬',
                title: 'Tecnología real, no demos',
                desc: 'Cada agente que desplegamos corre en producción con IA de última generación (Google Gemini), búsqueda semántica y memoria de conversación real.',
              },
              {
                icon: '🤝',
                title: 'Soporte cercano',
                desc: 'No eres un ticket. Cuando algo falla o quieres ajustar el tono del agente, hablamos directamente contigo por WhatsApp.',
              },
              {
                icon: '🔒',
                title: 'Tus datos, en tu servidor',
                desc: 'La plataforma es desplegable en tu propio VPS. Tus conversaciones y base de conocimiento no salen de tu infraestructura.',
              },
              {
                icon: '📈',
                title: 'Mejora continua',
                desc: 'Revisamos los escalados y los fallos del agente contigo para afinar las respuestas y reducir la carga en tu equipo semana a semana.',
              },
            ].map((v) => (
              <div class="flex gap-4 p-5 rounded-2xl border border-gray-100 hover:border-[#25D366]/30 hover:shadow-sm transition-all bg-white">
                <span class="text-2xl shrink-0">{v.icon}</span>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-1">{v.title}</h3>
                  <p class="text-sm text-gray-500 leading-relaxed">{v.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CTA + CONTACTO ===================== -->
    <section id="contacto" class="py-24 bg-gradient-to-br from-[#0B5E55] via-[#128C7E] to-[#25D366]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
            Empieza hoy. Sin compromiso.
          </h2>
          <p class="text-white/70 text-lg">
            Cuéntanos sobre tu negocio y te mostramos cómo funcionaría Dalsat para ti.
          </p>
        </div>

        <div class="bg-white rounded-3xl p-8 sm:p-12 shadow-2xl">
          <ContactForm client:visible />
        </div>

        <div class="mt-8 text-center text-white/50 text-sm">
          También puedes escribirnos a{' '}
          <a href="mailto:dalsat.soluciones@gmail.com" class="text-white/80 underline hover:text-white">
            dalsat.soluciones@gmail.com
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <div class="flex items-center gap-2.5">
        <img src="/logo_sin_fondo.png" alt="Dalsat logo" class="h-8 w-auto brightness-0 invert opacity-80" />
        <span class="font-semibold text-white">Dalsat</span>
      </div>
      <p>&copy; 2025 Dalsat. Todos los derechos reservados.</p>
      <a href="mailto:dalsat.soluciones@gmail.com" class="hover:text-white transition-colors">dalsat.soluciones@gmail.com</a>
    </div>
  </footer>
