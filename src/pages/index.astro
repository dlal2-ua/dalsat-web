---
import Layout from '../layouts/Layout.astro';
import ChatDemo from '../components/ChatDemo';
import ContactForm from '../components/ContactForm';
---

<Layout title="Dalsat — Automatización e IA para negocios" description="Dalsat diseña e implanta agentes de IA e integraciones que automatizan tu negocio: WhatsApp, calendario, email, facturación y más. Sin código, listo en días.">
  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/logo_sin_fondo.png" alt="Dalsat logo" class="h-11 w-auto" />
        <span class="font-bold text-[#001A3F] text-lg">Dalsat</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
        <a href="#servicios" class="hover:text-[#001A3F] transition-colors">Servicios</a>
        <a href="#como-funciona" class="hover:text-[#001A3F] transition-colors">Cómo funciona</a>
        <a href="#prueba-social" class="hover:text-[#001A3F] transition-colors">Casos reales</a>
        <a href="#quienes-somos" class="hover:text-[#001A3F] transition-colors">Quiénes somos</a>
      </nav>
      <a
        href="#contacto"
        class="bg-[#001A3F] hover:bg-[#00E0FF] hover:text-[#001A3F] text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors shadow-sm"
      >
        Hablar con nosotros →
      </a>
    </div>
  </header>

  <main class="pt-16">
    <!-- ===================== HERO ===================== -->
    <section class="relative overflow-hidden bg-[#001A3F] pt-20 pb-24 sm:pt-28 sm:pb-32">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full bg-[#00E0FF]/8 translate-x-1/3 -translate-y-1/3" />
        <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full bg-[#00E0FF]/5 -translate-x-1/3 translate-y-1/3" />
      </div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-[#00E0FF]/10 border border-[#00E0FF]/20 text-[#00E0FF] text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-[#00E0FF] animate-pulse" />
            Agentes de IA para negocios reales
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
            Tu negocio en&nbsp;
            <span class="text-[#00E0FF]">piloto automático</span>
          </h1>
          <p class="text-lg sm:text-xl text-white/60 mb-10 leading-relaxed max-w-lg">
            Dalsat diseña e implanta agentes de IA e integraciones que automatizan las tareas repetitivas de tu negocio: atención en WhatsApp, gestión de agenda, emails, facturación y más.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contacto"
              class="inline-flex items-center justify-center gap-2 bg-[#00E0FF] hover:bg-white text-[#001A3F] font-semibold px-8 py-4 rounded-xl transition-colors shadow-lg shadow-[#00E0FF]/20 text-base"
            >
              Automatiza tu negocio
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a
              href="#servicios"
              class="inline-flex items-center justify-center gap-2 text-white/70 hover:text-white font-medium px-8 py-4 rounded-xl border border-white/20 hover:border-white/50 transition-colors text-base"
            >
              Ver servicios
            </a>
          </div>
          <div class="mt-10 flex items-center gap-6 text-sm text-white/40">
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-[#00E0FF]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Sin código
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-[#00E0FF]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Listo en días
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-[#00E0FF]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              24/7 activo
            </div>
          </div>
        </div>

        <!-- Chat preview hero -->
        <div class="lg:flex justify-center hidden">
          <ChatDemo client:visible />
        </div>
      </div>
    </section>

    <!-- ===================== SERVICIOS / INTEGRACIONES ===================== -->
    <section id="servicios" class="py-24 bg-[#F2F4F7]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16">
          <span class="text-xs font-bold uppercase tracking-widest text-[#00E0FF] bg-[#001A3F] px-3 py-1 rounded-full mb-4 inline-block">Servicios</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mt-4 mb-4">Todo lo que podemos automatizar</h2>
          <p class="text-gray-500 text-lg max-w-xl mx-auto">
            Cada negocio es distinto. Te ayudamos a identificar dónde pierdes más tiempo y lo automatizamos.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            {
              icon: '💬',
              title: 'Agente WhatsApp',
              badge: 'Disponible',
              badgeColor: 'bg-emerald-100 text-emerald-700',
              desc: 'Responde preguntas frecuentes, gestiona citas y escala a un humano cuando hace falta. Activo 24/7, sin intervención tuya.',
              highlight: true,
            },
            {
              icon: '📅',
              title: 'Gestión de calendario',
              badge: 'Disponible',
              badgeColor: 'bg-emerald-100 text-emerald-700',
              desc: 'Integración con Google Calendar: reservas automáticas, recordatorios y gestión de disponibilidad sin ir y venir de emails.',
              highlight: false,
            },
            {
              icon: '📧',
              title: 'Automatización de Gmail',
              badge: 'Disponible',
              badgeColor: 'bg-emerald-100 text-emerald-700',
              desc: 'Clasificación, respuestas automáticas a consultas habituales y flujos de seguimiento. Tu bandeja de entrada bajo control.',
              highlight: false,
            },
            {
              icon: '🧾',
              title: 'Facturación automática',
              badge: 'Próximamente',
              badgeColor: 'bg-amber-100 text-amber-700',
              desc: 'Generación y envío de facturas disparados por eventos: confirmación de cita, pago recibido, cierre de servicio.',
              highlight: false,
            },
            {
              icon: '🔗',
              title: 'Integraciones a medida',
              badge: 'A consultar',
              badgeColor: 'bg-blue-100 text-blue-700',
              desc: 'CRM, ERP, TPV, plataformas de reservas... Si ya usas una herramienta, estudiamos cómo conectarla a tu flujo automatizado.',
              highlight: false,
            },
            {
              icon: '📊',
              title: 'Reportes e informes',
              badge: 'Próximamente',
              badgeColor: 'bg-amber-100 text-amber-700',
              desc: 'Resúmenes automáticos de actividad, conversaciones y métricas clave directamente en tu email o WhatsApp cada semana.',
              highlight: false,
            },
          ].map((s) => (
            <div class={`rounded-2xl p-6 border transition-all hover:shadow-lg ${s.highlight ? 'bg-[#001A3F] border-[#001A3F]' : 'bg-white border-gray-100 hover:border-[#00E0FF]/40'}`}>
              <div class="flex items-start justify-between mb-4">
                <span class="text-3xl">{s.icon}</span>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${s.badgeColor}`}>{s.badge}</span>
              </div>
              <h3 class={`font-bold text-base mb-2 ${s.highlight ? 'text-white' : 'text-[#001A3F]'}`}>{s.title}</h3>
              <p class={`text-sm leading-relaxed ${s.highlight ? 'text-white/60' : 'text-gray-500'}`}>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== PROBLEMA / SOLUCIÓN ===================== -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <!-- Problema -->
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-red-500 mb-4 block">El problema</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mb-6">
              Las tareas repetitivas te roban horas cada día
            </h2>
            <ul class="space-y-4">
              {[
                'Responder las mismas preguntas una y otra vez',
                'Confirmar citas y enviar recordatorios manualmente',
                'Reenviar presupuestos y facturas a mano',
                'Buscar huecos en el calendario para cada cliente',
              ].map((q) => (
                <li class="flex items-start gap-3 p-4 bg-[#F2F4F7] rounded-xl border border-gray-100">
                  <span class="text-red-400 mt-0.5">✕</span>
                  <div>
                    <p class="font-medium text-gray-800">"{q}"</p>
                    <p class="text-sm text-gray-400 mt-0.5">Tiempo tuyo desperdiciado que un agente puede hacer en segundos.</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <!-- Solución -->
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-[#00E0FF] bg-[#001A3F] px-2 py-0.5 rounded mb-4 inline-block">La solución</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mb-6 mt-2">
              Dalsat lo automatiza, tú te centras en crecer
            </h2>
            <div class="space-y-4">
              {[
                {
                  icon: '⚡',
                  title: 'Respuesta en segundos',
                  desc: 'Tus agentes contestan, reservan y gestionan en tiempo real, a cualquier hora.',
                },
                {
                  icon: '🎯',
                  title: 'Contexto de tu negocio',
                  desc: 'Conocen tus precios, horarios, servicios y tono de voz. No son bots genéricos.',
                },
                {
                  icon: '🤝',
                  title: 'Escalan cuando toca',
                  desc: 'Si el cliente necesita un humano, te avisan con el contexto completo de la conversación.',
                },
              ].map((item) => (
                <div class="flex items-start gap-4 p-4 bg-[#F2F4F7] rounded-xl border border-gray-100">
                  <span class="text-2xl">{item.icon}</span>
                  <div>
                    <p class="font-semibold text-[#001A3F]">{item.title}</p>
                    <p class="text-sm text-gray-500 mt-0.5">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CÓMO FUNCIONA ===================== -->
    <section id="como-funciona" class="py-24 bg-[#F2F4F7]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
        <span class="text-xs font-bold uppercase tracking-widest text-[#00E0FF] bg-[#001A3F] px-3 py-1 rounded-full mb-4 inline-block">Proceso</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mt-4 mb-4">Listo en 3 pasos</h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto mb-16">
          Sin técnicos de tu lado, sin semanas de espera. Tu automatización activa en días.
        </p>

        <div class="grid md:grid-cols-3 gap-8 relative">
          <div class="hidden md:block absolute top-12 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-[#00E0FF] to-[#001A3F] opacity-30" />

          {[
            {
              step: '01',
              icon: '📋',
              title: 'Nos cuentas tu negocio',
              desc: 'Horarios, servicios, precios, flujos de trabajo. Puedes subir PDFs, Word o Excel. Nosotros nos encargamos del resto.',
            },
            {
              step: '02',
              icon: '🤖',
              title: 'Configuramos los agentes',
              desc: 'Diseñamos e implantamos las integraciones adaptadas a tu negocio. Sin ingeniería de tu parte.',
            },
            {
              step: '03',
              icon: '🚀',
              title: 'Tu negocio se automatiza',
              desc: 'Los agentes trabajan por ti. Tú solo gestionas lo que realmente necesita tu atención.',
            },
          ].map((item) => (
            <div class="relative bg-white rounded-2xl p-8 text-left border border-gray-100 hover:border-[#00E0FF]/40 hover:shadow-lg transition-all">
              <div class="text-4xl mb-4">{item.icon}</div>
              <div class="text-xs font-bold text-[#00E0FF] bg-[#001A3F] px-2 py-0.5 rounded inline-block mb-2">PASO {item.step}</div>
              <h3 class="text-lg font-bold text-[#001A3F] mb-2">{item.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== CAPACIDADES ===================== -->
    <section id="funcionalidades" class="py-24 bg-[#001A3F]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16">
          <span class="text-xs font-bold uppercase tracking-widest text-[#00E0FF] mb-4 block">Capacidades</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Tecnología real. No demos.</h2>
          <p class="text-white/60 text-lg max-w-xl mx-auto">
            Cada agente corre en producción con IA de última generación y se adapta a las particularidades de tu negocio.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            {
              icon: '🧠',
              title: 'IA con contexto de tu negocio',
              desc: 'Los agentes conocen tus servicios, precios, horarios y tono de voz. No son chatbots genéricos.',
            },
            {
              icon: '🔍',
              title: 'Búsqueda semántica',
              desc: 'Encuentra la información correcta aunque el cliente no use las palabras exactas de tus documentos.',
            },
            {
              icon: '💬',
              title: 'Memoria de conversación',
              desc: 'Los agentes recuerdan el contexto de la conversación. Los clientes no tienen que repetirse.',
            },
            {
              icon: '📤',
              title: 'Escalado inteligente',
              desc: 'Detecta cuándo escalar a humano y te notifica con el resumen completo de la conversación.',
            },
            {
              icon: '📁',
              title: 'Ingestión de documentos',
              desc: 'Sube PDFs, Word y Excel. El agente los procesa y los convierte en base de conocimiento.',
            },
            {
              icon: '🔗',
              title: 'Multi-integración',
              desc: 'WhatsApp, Calendar, Gmail, CRMs... Los agentes se conectan a las herramientas que ya usas.',
            },
          ].map((f) => (
            <div class="bg-white/8 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:bg-white/12 hover:border-[#00E0FF]/30 transition-all">
              <div class="text-3xl mb-4">{f.icon}</div>
              <h3 class="text-white font-semibold text-base mb-2">{f.title}</h3>
              <p class="text-white/60 text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== DIFERENCIADORES ===================== -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mb-4">Dalsat vs. las alternativas</h2>
          <p class="text-gray-500">Por qué no lo hacen igual que nosotros.</p>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100">
                <th class="text-left py-4 pr-4 text-gray-400 font-medium w-1/3"></th>
                <th class="text-center py-4 px-3 text-gray-400 font-medium">Herramientas genéricas</th>
                <th class="text-center py-4 px-3 text-gray-400 font-medium">Desarrollo a medida</th>
                <th class="text-center py-4 px-3 bg-[#F2F4F7] rounded-t-xl font-bold text-[#001A3F]">Dalsat</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['Tiempo de implantación', 'Días–semanas', 'Semanas–meses', 'Días'],
                ['Conoce tu negocio', 'Entrenamiento manual', 'Desarrollo a medida', 'Auto desde config'],
                ['Multi-canal', 'Raramente', 'A veces', 'Siempre'],
                ['Escalado a humano', 'Limitado', 'A medida', 'Integrado'],
                ['Soporte directo', '✕', 'Variable', '✓ WhatsApp'],
                ['Precio', 'Medio', 'Alto', 'Asequible'],
              ].map(([label, generic, custom, dalsat]) => (
                <tr class="border-b border-gray-50">
                  <td class="py-4 pr-4 text-gray-700 font-medium">{label}</td>
                  <td class="py-4 px-3 text-center text-gray-400">{generic}</td>
                  <td class="py-4 px-3 text-center text-gray-400">{custom}</td>
                  <td class="py-4 px-3 text-center bg-[#F2F4F7] text-[#001A3F] font-semibold">{dalsat}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ===================== PRUEBA SOCIAL ===================== -->
    <section id="prueba-social" class="py-24 bg-[#F2F4F7]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16">
          <span class="text-xs font-bold uppercase tracking-widest text-[#00E0FF] bg-[#001A3F] px-3 py-1 rounded-full mb-4 inline-block">Caso real</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mt-4 mb-4">
            Autoescuela Reyes — Valencia
          </h2>
          <p class="text-gray-500 text-lg max-w-xl mx-auto">
            Agente WhatsApp que responde sobre carnets, precios, documentación y proceso de examen. Disponible 24/7. Escala a humano para consultas personalizadas.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            {[
              {
                icon: '🚗',
                label: 'Carnets gestionados',
                value: 'B, A2, AM',
                desc: 'Responde con detalle sobre cada tipo de carnet',
              },
              {
                icon: '⏰',
                label: 'Disponibilidad',
                value: '24 / 7',
                desc: 'Consultas fuera de horario resueltas sin personal',
              },
              {
                icon: '📞',
                label: 'Escalado automático',
                value: 'Activo',
                desc: 'Expedientes concretos y fechas de examen → humano',
              },
              {
                icon: '🗣️',
                label: 'Tono de voz',
                value: 'Cercano',
                desc: 'Español informal, adaptado a la marca de la autoescuela',
              },
            ].map((stat) => (
              <div class="flex items-start gap-4 p-5 bg-white rounded-2xl border border-gray-100 shadow-sm">
                <span class="text-2xl">{stat.icon}</span>
                <div class="flex-1">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-500">{stat.label}</span>
                    <span class="font-bold text-[#001A3F] text-sm">{stat.value}</span>
                  </div>
                  <p class="text-xs text-gray-400 mt-0.5">{stat.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <ChatDemo client:visible />
        </div>
      </div>
    </section>


<!-- ===================== QUIÉNES SOMOS ===================== -->
    <section id="quienes-somos" class="py-24 bg-[#F2F4F7]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex justify-center mb-14">
          <img
            src="/logo_sin_fondo.png"
            alt="Dalsat"
            class="h-36 w-auto drop-shadow-md"
          />
        </div>
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-[#00E0FF] bg-[#001A3F] px-3 py-1 rounded-full mb-4 inline-block">Quiénes somos</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mb-6 mt-4">
              Construido por gente que entiende tu negocio
            </h2>
            <p class="text-gray-500 text-lg leading-relaxed mb-6">
              Dalsat nació de una frustración real: ver cómo negocios brillantes perdían tiempo y clientes en tareas que una máquina puede hacer mejor y más rápido.
            </p>
            <p class="text-gray-500 leading-relaxed mb-6">
              Somos un equipo técnico con experiencia en inteligencia artificial y automatización. No vendemos humo — implantamos agentes reales, en producción, para negocios reales. Cada integración la supervisamos de principio a fin.
            </p>
            <p class="text-gray-500 leading-relaxed">
              Nuestra obsesión es que la automatización sea invisible para tus clientes — que siempre tengan respuesta, siempre al momento, exactamente como tú lo harías.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              {[
                { label: 'Agentes desplegados', value: '10+' },
                { label: 'Mensajes gestionados', value: '50.000+' },
                { label: 'Disponibilidad', value: '99,9 %' },
              ].map((stat) => (
                <div class="bg-white rounded-2xl px-6 py-4 border border-gray-100 text-center shadow-sm">
                  <div class="text-2xl font-extrabold text-[#001A3F]">{stat.value}</div>
                  <div class="text-xs text-gray-500 mt-0.5">{stat.label}</div>
                </div>
              ))}
            </div>
          </div>

          <div class="space-y-5">
            {[
              {
                icon: '🔬',
                title: 'Tecnología real, no demos',
                desc: 'Cada agente que implantamos corre en producción con IA de última generación, búsqueda semántica y memoria de conversación real.',
              },
              {
