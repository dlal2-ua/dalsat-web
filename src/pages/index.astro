---
import Layout from '../layouts/Layout.astro';
import SplitHero from '../components/SplitHero';
import SatisfiedClients from '../components/SatisfiedClients';
import ServiceTabs from '../components/ServiceTabs';
import AboutUs from '../components/AboutUs';
import MobileMenu from '../components/MobileMenu';
import ContactForm from '../components/ContactForm';

// Teléfono real de WhatsApp de Dalsat
const WHATSAPP_URL = 'https://wa.me/34646005171';
---

<Layout
  title="Dalsat — Automatización e IA para negocios"
  description="Dalsat diseña e implanta agentes de IA e integraciones que automatizan tu negocio: WhatsApp, calendario, email, facturación y más. Sin código, listo en días."
>
  <!-- ===================== NAVBAR ===================== -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-[#001A3F]/80 backdrop-blur-md border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2.5">
        <img src="/logo_sin_fondo.png" alt="Dalsat logo" width="44" height="44" class="h-10 w-auto object-contain brightness-0 invert" />
        <span class="font-display font-bold text-white text-lg tracking-wider">DALSAT</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-white/70" aria-label="Menú principal">
        <a href="#servicios" class="hover:text-white transition-colors">Servicios</a>
        <a href="#como-funciona" class="hover:text-white transition-colors">Cómo funciona</a>
        <a href="#quienes-somos" class="hover:text-white transition-colors">Quiénes somos</a>
        <a href="#contacto" class="hover:text-white transition-colors">Contacto</a>
      </nav>
      <div class="flex items-center gap-2">
        <a
          href="#contacto"
          class="hidden md:inline-flex bg-[#00E0FF] hover:bg-white text-[#001A3F] text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors shadow-sm"
        >
          Hablar con nosotros →
        </a>
        <MobileMenu client:load />
      </div>
    </div>
  </header>

  <main>
    <!-- ===================== 1. HERO GALÁCTICO: SPLIT + CHAT ===================== -->
    <SplitHero client:load />

    <!-- ===================== 1.5. EMPRESAS SATISFECHAS (SCROLL INTERACTIVO) ===================== -->
    <SatisfiedClients client:load />

    <!-- ===================== 2. SERVICIOS (SCROLL INTERACTIVO) ===================== -->
    <ServiceTabs client:load />

    <!-- ===================== 4. CÓMO FUNCIONA ===================== -->
    <section id="como-funciona" class="relative min-h-screen flex items-center bg-[#000814] py-28 border-t border-white/10 overflow-hidden">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-[size:32px_32px]" aria-hidden="true"></div>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 w-full text-center relative z-10">
        <span class="text-xs font-extrabold uppercase tracking-widest text-[#00E0FF] border border-[#00E0FF]/30 bg-[#00E0FF]/10 px-4 py-1.5 rounded-full inline-block backdrop-blur-md shadow-[0_0_15px_rgba(0,224,255,0.2)]">Proceso</span>
        <h2 class="text-4xl sm:text-5xl font-extrabold text-white mt-5 mb-4 tracking-tight">Listo en 3 pasos</h2>
        <p class="text-white/60 text-lg max-w-xl mx-auto mb-20">
          Sin técnicos de tu lado, sin semanas de espera. Tu automatización activa en días.
        </p>

        <div class="relative grid md:grid-cols-3 gap-10 md:gap-8 md:pl-0 pl-10">
          <!-- Línea conectora horizontal (desktop) -->
          <div class="hidden md:block absolute top-20 left-[16%] right-[16%] h-1 bg-gradient-to-r from-[#00E0FF] via-[#7C6BD6] to-[#00E0FF] shadow-[0_0_15px_rgba(0,224,255,0.5)]" aria-hidden="true"></div>
          <!-- Línea conectora vertical (mobile) -->
          <div class="md:hidden absolute left-8 top-10 bottom-10 w-1 bg-gradient-to-b from-[#00E0FF] via-[#7C6BD6] to-[#00E0FF] shadow-[0_0_15px_rgba(0,224,255,0.5)]" aria-hidden="true"></div>

          {
            [
              {
                step: '01',
                title: 'Cuéntanos tu negocio',
                desc: 'Subes documentos, nos explicas tus flujos, horarios y servicios. Nosotros nos encargamos del resto.',
                time: '30 minutos de reunión',
                icon: 'M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 8.25h7.5m-7.5 3h7.5m3-9v9a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V4.5a2.25 2.25 0 0 1 2.25-2.25h5.379c.597 0 1.17.237 1.591.659l4.621 4.621c.422.422.659.994.659 1.591Z',
              },
              {
                step: '02',
                title: 'Diseñamos tu agente',
                desc: 'Configuramos e integramos el agente con tus herramientas, adaptado a tu tono de voz y a tu forma de trabajar.',
                time: '3-5 días',
                icon: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z',
              },
              {
                step: '03',
                title: 'Activamos y mejoramos',
                desc: 'Tu agente entra en producción y lo afinamos contigo semana a semana revisando conversations reales.',
                time: 'Desde el día 1, activo 24/7',
                icon: 'M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z',
              },
            ].map((item) => (
              <div class="group relative bg-gradient-to-b from-white/[0.09] to-white/[0.02] rounded-3xl p-8 text-left border border-white/10 hover:border-[#00E0FF]/60 hover:-translate-y-2 hover:shadow-[0_15px_35px_rgba(0,224,255,0.15)] backdrop-blur-xl transition-all duration-300 overflow-hidden">
                <div class="absolute -right-10 -bottom-10 w-32 h-32 bg-[#00E0FF]/10 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-500 pointer-events-none"></div>
                
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#001A3F] to-[#00337A] border border-white/15 flex items-center justify-center mb-6 shadow-xl group-hover:scale-110 group-hover:border-[#00E0FF]/50 transition-all duration-300 relative z-10">
                  <svg class="w-8 h-8 text-[#00E0FF]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                  </svg>
                </div>
                <div class="relative z-10">
                  <div class="text-xs font-extrabold text-[#00E0FF] bg-[#00E0FF]/15 border border-[#00E0FF]/30 px-3 py-1 rounded-full inline-block mb-3 shadow-[0_0_10px_rgba(0,224,255,0.2)]">PASO {item.step}</div>
                  <h3 class="text-xl font-bold text-white mb-3 group-hover:text-[#00E0FF] transition-colors">{item.title}</h3>
                  <p class="text-white/70 text-sm leading-relaxed mb-6">{item.desc}</p>
                  <div class="inline-flex items-center gap-2 text-xs font-bold text-[#00E0FF] bg-white/5 py-2 px-3.5 rounded-xl border border-white/10">
                    <svg class="w-4 h-4 shrink-0 text-[#00E0FF]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    {item.time}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===================== 5. QUIÉNES SOMOS ===================== -->
    <!-- ===================== 5. QUIÉNES SOMOS ===================== -->
    <AboutUs client:load />

    <!-- ===================== 6. CTA + CONTACTO ===================== -->
    <section id="contacto" class="relative min-h-screen flex items-center bg-gradient-to-b from-[#000A18] via-[#00122E] to-[#000814] py-28 border-t border-white/10 overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[350px] bg-[#00E0FF]/15 rounded-full blur-[140px] pointer-events-none" aria-hidden="true"></div>
      
      <div class="max-w-4xl mx-auto px-4 sm:px-6 w-full relative z-10">
        <div class="text-center mb-14">
          <span class="text-xs font-extrabold uppercase tracking-widest text-[#00E0FF] border border-[#00E0FF]/30 bg-[#00E0FF]/10 px-4 py-1.5 rounded-full inline-block backdrop-blur-md shadow-[0_0_15px_rgba(0,224,255,0.2)] mb-4">Contacto</span>
          <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-5 tracking-tight">
            Empieza hoy. Sin compromiso.
          </h2>
          <p class="text-white/70 text-lg max-w-xl mx-auto">
            Cuéntanos sobre tu negocio y te mostramos qué podemos automatizar para ti.
          </p>
        </div>

        <div class="bg-gradient-to-b from-white/[0.09] to-white/[0.02] border border-white/15 rounded-3xl p-8 sm:p-12 shadow-[0_25px_60px_rgba(0,0,0,0.6)] backdrop-blur-2xl">
          <ContactForm client:visible />
        </div>

        <div class="mt-10 flex flex-col items-center gap-4">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 shadow-[0_10px_25px_rgba(37,211,102,0.3)] hover:shadow-[0_15px_35px_rgba(37,211,102,0.5)] hover:scale-105 text-base"
          >
            <svg class="w-6 h-6 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
            </svg>
            <span>Escríbeme por WhatsApp: <strong class="underline decoration-white/60 underline-offset-4">646 00 51 71</strong></span>
          </a>
          <p class="text-white/50 text-sm">
            También por email:{' '}
            <a href="mailto:dalsat.soluciones@gmail.com" class="text-white underline hover:text-[#00E0FF] transition-colors">
              dalsat.soluciones@gmail.com
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>

  <!-- ===================== 7. FOOTER ===================== -->
  <footer class="bg-[#000F26] text-gray-400 py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <div class="flex items-center gap-2.5">
        <img src="/logo_sin_fondo.png" alt="Dalsat logo" width="32" height="32" class="h-8 w-auto object-contain brightness-0 invert opacity-80" loading="lazy" />
        <span class="font-display font-semibold text-white tracking-wider">DALSAT</span>
      </div>
      <p>&copy; 2026 Dalsat. Todos los derechos reservados.</p>
      <a href="mailto:dalsat.soluciones@gmail.com" class="hover:text-white transition-colors">dalsat.soluciones@gmail.com</a>
    </div>
  </footer>
</Layout>
