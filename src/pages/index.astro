---
import Layout from '../layouts/Layout.astro';
import SplitHero from '../components/SplitHero';
import ServiceTabs from '../components/ServiceTabs';
import MobileMenu from '../components/MobileMenu';
import ContactForm from '../components/ContactForm';

// TODO: sustituir por el número real de WhatsApp de Dalsat (formato internacional sin +)
const WHATSAPP_URL = 'https://wa.me/34600000000';
---

<Layout
  title="Dalsat — Automatización e IA para negocios"
  description="Dalsat diseña e implanta agentes de IA e integraciones que automatizan tu negocio: WhatsApp, calendario, email, facturación y más. Sin código, listo en días."
>
  <!-- ===================== NAVBAR ===================== -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-[#001A3F]/80 backdrop-blur-md border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2.5">
        <img src="/logo_sin_fondo.png" alt="Dalsat logo" width="44" height="44" class="h-10 w-auto object-contain brightness-0 invert" />
        <span class="font-display font-bold text-white text-lg tracking-wider">DALSAT</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-white/70" aria-label="Menú principal">
        <a href="#servicios" class="hover:text-white transition-colors">Servicios</a>
        <a href="#como-funciona" class="hover:text-white transition-colors">Cómo funciona</a>
        <a href="#quienes-somos" class="hover:text-white transition-colors">Quiénes somos</a>
        <a href="#contacto" class="hover:text-white transition-colors">Contacto</a>
      </nav>
      <div class="flex items-center gap-2">
        <a
          href="#contacto"
          class="hidden md:inline-flex bg-[#00E0FF] hover:bg-white text-[#001A3F] text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors shadow-sm"
        >
          Hablar con nosotros →
        </a>
        <MobileMenu client:load />
      </div>
    </div>
  </header>

  <main>
    <!-- ===================== 1. HERO GALÁCTICO: SPLIT + CHAT ===================== -->
    <SplitHero client:load />

    <!-- ===================== 2. SERVICIOS CON TABS ===================== -->
    <section id="servicios" class="min-h-screen flex items-center bg-[#F2F4F7] py-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 w-full">
        <div class="reveal-zoom text-center mb-12">
          <span class="text-xs font-bold uppercase tracking-widest text-[#00E0FF] bg-[#001A3F] px-3 py-1 rounded-full inline-block">Servicios</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mt-4 mb-4">¿En qué te ayudamos?</h2>
          <p class="text-gray-500 text-lg max-w-xl mx-auto">
            Todo lo que automatizamos para que tu negocio funcione solo
          </p>
        </div>
        <ServiceTabs client:visible />
      </div>
    </section>

    <!-- ===================== 4. CÓMO FUNCIONA ===================== -->
    <section id="como-funciona" class="min-h-screen flex items-center bg-[#F2F4F7] py-24 border-t border-gray-200/60">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 w-full text-center">
        <div class="reveal">
          <span class="text-xs font-bold uppercase tracking-widest text-[#00E0FF] bg-[#001A3F] px-3 py-1 rounded-full inline-block">Proceso</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mt-4 mb-4">Listo en 3 pasos</h2>
          <p class="text-gray-500 text-lg max-w-xl mx-auto mb-16">
            Sin técnicos de tu lado, sin semanas de espera. Tu automatización activa en días.
          </p>
        </div>

        <div class="relative grid md:grid-cols-3 gap-10 md:gap-8 md:pl-0 pl-10">
          <!-- Línea conectora horizontal (desktop) -->
          <div class="hidden md:block absolute top-16 left-[16%] right-[16%] h-0.5 bg-gradient-to-r from-[#00E0FF]/60 via-[#001A3F]/30 to-[#00E0FF]/60" aria-hidden="true"></div>
          <!-- Línea conectora vertical (mobile) -->
          <div class="md:hidden absolute left-3 top-10 bottom-10 w-0.5 bg-gradient-to-b from-[#00E0FF]/60 to-[#001A3F]/30" aria-hidden="true"></div>

          {
            [
              {
                step: '01',
                title: 'Cuéntanos tu negocio',
                desc: 'Subes documentos, nos explicas tus flujos, horarios y servicios. Nosotros nos encargamos del resto.',
                time: '30 minutos de reunión',
                icon: 'M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 8.25h7.5m-7.5 3h7.5m3-9v9a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V4.5a2.25 2.25 0 0 1 2.25-2.25h5.379c.597 0 1.17.237 1.591.659l4.621 4.621c.422.422.659.994.659 1.591Z',
              },
              {
                step: '02',
                title: 'Diseñamos tu agente',
                desc: 'Configuramos e integramos el agente con tus herramientas, adaptado a tu tono de voz y a tu forma de trabajar.',
                time: '3-5 días',
                icon: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z',
              },
              {
                step: '03',
                title: 'Activamos y mejoramos',
                desc: 'Tu agente entra en producción y lo afinamos contigo semana a semana revisando conversaciones reales.',
                time: 'Desde el día 1, activo 24/7',
                icon: 'M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z',
              },
            ].map((item, i) => (
              <div
                class="reveal-zoom group relative bg-white rounded-2xl p-8 text-left border border-gray-100 hover:border-[#00E0FF]/40 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                style={`--reveal-delay: ${i * 150}ms`}
              >
                <div class="w-16 h-16 rounded-2xl bg-[#001A3F] flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110">
                  <svg class="w-8 h-8 text-[#00E0FF]" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-bold text-[#00E0FF] bg-[#001A3F] px-2 py-0.5 rounded inline-block mb-2">PASO {item.step}</div>
                  <h3 class="text-lg font-bold text-[#001A3F] mb-2">{item.title}</h3>
                  <p class="text-gray-500 text-sm leading-relaxed mb-4">{item.desc}</p>
                  <div class="flex items-center gap-1.5 text-xs font-semibold text-[#001A3F]">
                    <svg class="w-4 h-4 text-[#00E0FF]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    {item.time}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===================== 5. QUIÉNES SOMOS ===================== -->
    <section id="quienes-somos" class="min-h-screen flex items-center bg-white py-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 w-full">
        <div class="reveal-roll flex justify-center mb-12">
          <button
            id="dalsat-logo-trigger"
            type="button"
            aria-label="Iluminar nuestros valores"
            class="logo-trigger rounded-full p-2 cursor-pointer transition-transform duration-300 hover:scale-105 active:scale-95 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#00E0FF]"
          >
            <img src="/logo_sin_fondo.png" alt="Dalsat logo" width="180" height="128" class="h-32 w-auto object-contain drop-shadow-md pointer-events-none" loading="lazy" />
          </button>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="reveal-left">
            <span class="text-xs font-bold uppercase tracking-widest text-[#00E0FF] bg-[#001A3F] px-3 py-1 rounded-full inline-block">Quiénes somos</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-[#001A3F] mt-4 mb-6">
              Construido por gente que entiende tu negocio
            </h2>
            <p class="text-gray-500 text-lg leading-relaxed mb-4">
              Dalsat nació de una frustración real: ver cómo negocios brillantes perdían tiempo y clientes en tareas que una máquina puede hacer mejor y más rápido.
            </p>
            <p class="text-gray-500 leading-relaxed">
              Somos un equipo técnico con experiencia en IA y automatización. No vendemos humo — implantamos agentes reales, en producción, para negocios reales.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              {
                [
                  { label: 'Agentes desplegados', target: 10, decimals: 0, prefix: '', suffix: '+' },
                  { label: 'Mensajes gestionados', target: 50000, decimals: 0, prefix: '', suffix: '+' },
                  { label: 'Disponibilidad', target: 99.9, decimals: 1, prefix: '', suffix: ' %' },
                ].map((stat, i) => (
                  <div
                    class="reveal-zoom bg-[#F2F4F7] rounded-2xl px-6 py-4 border border-gray-100 text-center hover:-translate-y-1 hover:shadow-md transition-all duration-300"
                    style={`--reveal-delay: ${200 + i * 120}ms`}
                  >
                    <div
                      class="stat-number text-2xl font-extrabold text-[#001A3F]"
                      data-target={stat.target}
                      data-decimals={stat.decimals}
                      data-prefix={stat.prefix}
                      data-suffix={stat.suffix}
                    >
                      {stat.prefix}0{stat.suffix}
                    </div>
                    <div class="text-xs text-gray-500 mt-0.5">{stat.label}</div>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="reveal-right space-y-4">
            {
              [
                {
                  title: 'Tecnología real, no demos',
                  desc: 'Cada agente corre en producción con IA de última generación, búsqueda semántica y memoria de conversación.',
                  icon: 'M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5',
                },
                {
                  title: 'Soporte cercano',
                  desc: 'No eres un ticket. Cuando quieres ajustar el agente, hablamos directamente contigo por WhatsApp.',
                  icon: 'M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z',
                },
                {
                  title: 'Tus datos, en tu servidor',
                  desc: 'La plataforma es desplegable en tu propio VPS. Tus conversaciones no salen de tu infraestructura.',
                  icon: 'M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z',
                },
                {
                  title: 'Mejora continua',
                  desc: 'Revisamos escalados y fallos contigo para afinar el comportamiento de los agentes semana a semana.',
                  icon: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941',
                },
              ].map((v) => (
                <div class="value-card group flex gap-4 p-5 rounded-2xl border border-gray-100 hover:border-[#00E0FF]/40 hover:shadow-sm hover:-translate-x-1 transition-all duration-300 bg-[#F2F4F7]">
                  <div class="w-11 h-11 shrink-0 rounded-xl bg-[#001A3F] flex items-center justify-center transition-transform duration-300 group-hover:scale-110 group-hover:rotate-6">
                    <svg class="w-5 h-5 text-[#00E0FF]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d={v.icon} />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-[#001A3F] mb-1">{v.title}</h3>
                    <p class="text-sm text-gray-500 leading-relaxed">{v.desc}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== 6. CTA + CONTACTO ===================== -->
    <section id="contacto" class="min-h-screen flex items-center bg-[#001A3F] py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 w-full">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
            Empieza hoy. Sin compromiso.
          </h2>
          <p class="text-white/60 text-lg">
            Cuéntanos sobre tu negocio y te mostramos qué podemos automatizar para ti.
          </p>
        </div>

        <div class="bg-white rounded-3xl p-8 sm:p-12 shadow-2xl shadow-black/30">
          <ContactForm client:visible />
        </div>

        <div class="mt-8 flex flex-col items-center gap-4">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 bg-[#25D366] hover:bg-[#1ebe5b] text-white font-semibold px-7 py-3.5 rounded-xl transition-colors shadow-lg shadow-[#25D366]/20 text-sm"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
            </svg>
            O escríbenos directamente por WhatsApp
          </a>
          <p class="text-white/40 text-sm">
            También por email:{' '}
            <a href="mailto:dalsat.soluciones@gmail.com" class="text-white/70 underline hover:text-white transition-colors">
              dalsat.soluciones@gmail.com
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>

  <!-- ===================== 7. FOOTER ===================== -->
  <footer class="bg-[#000F26] text-gray-400 py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <div class="flex items-center gap-2.5">
        <img src="/logo_sin_fondo.png" alt="Dalsat logo" width="32" height="32" class="h-8 w-auto object-contain brightness-0 invert opacity-80" loading="lazy" />
        <span class="font-display font-semibold text-white tracking-wider">DALSAT</span>
      </div>
      <p>&copy; 2026 Dalsat. Todos los derechos reservados.</p>
      <div class="flex items-center gap-4">
        <a href="/politica-privacidad" class="hover:text-white transition-colors">Política de privacidad</a>
        <a href="/cookies" class="hover:text-white transition-colors">Cookies</a>
        <a href="mailto:dalsat.soluciones@gmail.com" class="hover:text-white transition-colors">dalsat.soluciones@gmail.com</a>
      </div>
    </div>
  </footer>

  <style>
    .logo-trigger {
      position: relative;
    }
    .logo-trigger::after {
      content: '';
      position: absolute;
      inset: -8px;
      border-radius: 9999px;
      background: radial-gradient(circle, rgba(0, 224, 255, 0.35), transparent 70%);
      opacity: 0;
      transform: scale(0.6);
      transition: opacity 0.4s ease, transform 0.4s ease;
      pointer-events: none;
    }
    .logo-trigger.pulse::after {
      opacity: 1;
      transform: scale(1.6);
      animation: logoPulseFade 0.9s ease-out forwards;
    }
    @keyframes logoPulseFade {
      0% { opacity: 0.9; transform: scale(1.1); }
      100% { opacity: 0; transform: scale(2.2); }
    }
    .logo-trigger.spin-once img {
      animation: logoSpinOnce 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }
    @keyframes logoSpinOnce {
      from { transform: rotate(0deg) scale(1); }
      50% { transform: rotate(180deg) scale(1.12); }
      to { transform: rotate(360deg) scale(1); }
    }

    .value-card {
      position: relative;
      overflow: hidden;
    }
    .value-card.lit {
      border-color: rgba(0, 224, 255, 0.7) !important;
      box-shadow: 0 0 0 1px rgba(0, 224, 255, 0.5), 0 10px 30px -8px rgba(0, 224, 255, 0.45);
      transform: translateY(-4px) scale(1.02);
      transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
    }
    .value-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 20%, rgba(0, 224, 255, 0.25) 50%, transparent 80%);
      transform: translateX(-120%);
      pointer-events: none;
    }
    .value-card.lit::before {
      animation: cardSweep 0.7s ease-out;
    }
    @keyframes cardSweep {
      from { transform: translateX(-120%); }
      to { transform: translateX(120%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .logo-trigger.spin-once img,
      .value-card.lit::before {
        animation: none;
      }
    }
  </style>

  <script>
    const logoTrigger = document.getElementById('dalsat-logo-trigger');
    const valueCards = Array.from(document.querySelectorAll<HTMLElement>('.value-card'));

    logoTrigger?.addEventListener('click', () => {
      logoTrigger.classList.remove('spin-once', 'pulse');
      // restart animations even on repeated clicks
      void logoTrigger.offsetWidth;
      logoTrigger.classList.add('spin-once', 'pulse');

      valueCards.forEach((card, i) => {
        card.classList.remove('lit');
        window.setTimeout(() => {
          card.classList.add('lit');
          window.setTimeout(() => card.classList.remove('lit'), 900);
        }, i * 220);
      });
    });

    const formatNumber = (value: number, decimals: number) =>
      value.toLocaleString('es-ES', {
        minimumFractionDigits: decimals,
        maximumFractionDigits: decimals,
      });

    const animateCount = (el: HTMLElement) => {
      const target = parseFloat(el.dataset.target ?? '0');
      const decimals = parseInt(el.dataset.decimals ?? '0', 10);
      const prefix = el.dataset.prefix ?? '';
      const suffix = el.dataset.suffix ?? '';
      const duration = 1400;
      const start = performance.now();

      const tick = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = target * eased;
        el.textContent = `${prefix}${formatNumber(current, decimals)}${suffix}`;
        if (progress < 1) requestAnimationFrame(tick);
      };

      requestAnimationFrame(tick);
    };

    const statObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            animateCount(entry.target as HTMLElement);
            statObserver.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.4 }
    );

    document.querySelectorAll<HTMLElement>('.stat-number').forEach((el) => statObserver.observe(el));
  </script>
</Layout>
