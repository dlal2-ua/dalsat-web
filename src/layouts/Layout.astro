---
import { Analytics } from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dalsat — Automatización e IA para negocios',
  description = 'Dalsat diseña e implanta agentes de IA e integraciones que automatizan tu negocio: WhatsApp, calendario, email, facturación y más. Sin código, listo en días.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/logo_sin_fondo.png" />
  </head>
  <body class="font-sans antialiased bg-white text-gray-900">
    <slot />
    <Analytics />
  </body>
</html>
